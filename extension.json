{
  "name": "security",
  "version": "1.0.0",
  "commands": ["/scan", "/audit", "/cve", "/policy"],
  "mainAI": "Security AI",
  "subAI": ["Security Audit AI"],
  "requires": {
    "server": true,
    "db": "postgresql"
  },
  "specPath": "./info.txt",
  "install": {
    "harness": {
      "copySpec": "doc/security_info.txt",
      "copyFiles": [
        { "from": "policy/secignore.template", "to": "doc/.secignore" },
        { "from": "config/.env.template", "to": "config/.env" },
        { "from": "config/.gitignore", "to": "config/.gitignore" }
      ],
      "createDirs": [
        "report/sec_fragments",
        "config"
      ]
    },
    "standalone": {
      "copySpec": "doc/security_info.txt",
      "copyFiles": [
        { "from": "policy/secignore.template", "to": "doc/.secignore" },
        { "from": "config/.env.template", "to": "config/.env" },
        { "from": "config/.gitignore", "to": "config/.gitignore" }
      ],
      "createDirs": [
        "doc",
        "report",
        "report/sec_fragments",
        "config"
      ]
    }
  }
}
